# cloud-init network-config for PumaGuard Raspberry Pi devices.
#
# This file is written to the system-boot partition of the SD card alongside
# user-data.  It is consumed by cloud-init on first boot only.
#
# Purpose: bring up the wired interface (eth0) via DHCP so the device is
# reachable over the local network for the initial Ansible provisioning run.
# The Ansible playbook (configure-device.yaml) will replace this with its own
# netplan configuration and disable cloud-init networking afterwards.
#
# wlan0 is intentionally left unconfigured here.  hostapd (deployed by the
# Ansible playbook) manages wlan0 as a Wi-Fi access point; letting cloud-init
# touch it on first boot would conflict with that setup.

version: 2
ethernets:
  eth0:
    dhcp4: true
    # Mark the interface optional so that if no cable is plugged in the boot
    # process does not stall waiting for a DHCP lease.
    optional: true
  wlan0:
    dhcp4: true
    optional: true
    access-points:
       "{{ "