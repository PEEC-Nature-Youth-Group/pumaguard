network:
  version: 2
  ethernets:
    eth0:
      dhcp4: true
  wifis:
    wlan0:
      dhcp4: false
      addresses: [192.168.52.1/24]
      nameservers:
        addresses: [192.168.52.1, 1.1.1.1]
      access-points:
        {{ pumaguard_ap.ssid }}:
          password: {{ pumaguard_ap.password }}
          mode: ap
